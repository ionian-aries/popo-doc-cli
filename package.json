{
  "name": "popo-doc-cli",
  "version": "1.1.0",
  "description": "POPO 文档命令行工具（Node.js）",
  "type": "module",
  "bin": {
    "popo-doc": "dist/index.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsup",
    "dev": "cross-env DEBUG=true tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run typecheck",
    "publish:public": "npm publish --registry=https://registry.npmjs.org"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ionian-aries/popo-doc-cli.git"
  },
  "keywords": [
    "cli",
    "docs",
    "popo"
  ],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ionian-aries/popo-doc-cli/issues"
  },
  "homepage": "https://github.com/ionian-aries/popo-doc-cli#readme",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.17"
  },
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "cross-env": "^10.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
